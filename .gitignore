# Node artifacts
node_modules/
**/node_modules/

# Frontend build output
frontend/dist/

# Backend local environment and runtime data
backend/.env.local
backend/data/
backend/*.exe
backend/*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/

# Terraform — never commit state or real variable values
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars
terraform/*.tfvars
terraform/override.tf
terraform/override.tf.json

